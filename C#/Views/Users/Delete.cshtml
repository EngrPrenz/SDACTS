@model SampleCRUD.Models.User
@{ ViewData["Title"] = "Delete User"; }

<div class="page-header">
    <div>
        <h2>🗑️ Delete User</h2>
        <p class="page-sub">This action cannot be undone</p>
    </div>
    <a asp-action="Index" class="btn-secondary">← Back</a>
</div>

<div class="card form-card">
    <div class="delete-warning">
        <p>Are you sure you want to delete this user?</p>
        <div class="delete-info">
            <div><span>Username:</span> <strong>@Model.Username</strong></div>
        </div>
    </div>

    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div class="form-actions">
            <button type="submit" class="btn-danger">Yes, Delete</button>
            <a asp-action="Index" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>