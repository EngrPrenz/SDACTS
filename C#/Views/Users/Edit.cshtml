@model SampleCRUD.Models.User
@{ ViewData["Title"] = "Edit User"; }

<div class="page-header">
    <div>
        <h2>✏️ Edit User</h2>
        <p class="page-sub">Update user #@Model.Id</p>
    </div>
    <a asp-action="Index" class="btn-secondary">← Back</a>
</div>

<div class="card form-card">
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="form-group">
            <label asp-for="Username">Username</label>
            <input asp-for="Username" class="form-control" />
            <span asp-validation-for="Username" class="field-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Password">Password</label>
            <input asp-for="Password" class="form-control" type="text" />
            <span asp-validation-for="Password" class="field-error"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary">Update User</button>
            <a asp-action="Index" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }