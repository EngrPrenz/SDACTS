@model IEnumerable<SampleCRUD.Models.User>
@{ ViewData["Title"] = "Users"; }

<div class="page-header">
    <div>
        <h2>👥 Users</h2>
        <p class="page-sub">Manage system users</p>
    </div>
    <a asp-controller="Users" asp-action="Create" class="btn-primary">+ Add User</a>
</div>

<div class="card">
    @if (!Model.Any())
    {
        <div class="empty-state">
            No users found. <a asp-action="Create">Add one →</a>
        </div>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Username</th>
                    <th>Password</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="id-col">@item.Id</td>
                        <td><strong>@item.Username</strong></td>
                        <td class="pwd-col">••••••••</td>
                        <td>
                            <a href="/Users/Edit/@item.Id" class="btn-edit">Edit</a>
                            <a href="/Users/Delete/@item.Id" class="btn-delete">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>