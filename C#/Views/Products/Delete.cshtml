@model SampleCRUD.Models.Product
@{ ViewData["Title"] = "Delete Product"; }

<div class="page-header">
    <div>
        <h2>🗑️ Delete Product</h2>
        <p class="page-sub">This action cannot be undone</p>
    </div>
    <a asp-action="Index" class="btn-secondary">← Back</a>
</div>

<div class="card form-card">
    <div class="delete-warning">
        <p>Are you sure you want to delete this product?</p>
        <div class="delete-info">
            <div><span>Name:</span> <strong>@Model.Name</strong></div>
            <div><span>Price:</span> <strong>₱@Model.Price.ToString("N2")</strong></div>
        </div>
    </div>

    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div class="form-actions">
            <button type="submit" class="btn-danger">Yes, Delete</button>
            <a asp-action="Index" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>