@model SampleCRUD.Models.Product
@{ ViewData["Title"] = "Edit Product"; }

<div class="page-header">
    <div>
        <h2>✏️ Edit Product</h2>
        <p class="page-sub">Update product #@Model.Id</p>
    </div>
    <a asp-action="Index" class="btn-secondary">← Back</a>
</div>

<div class="card form-card">
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="form-group">
            <label asp-for="Name">Product Name</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="field-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Price">Price</label>
            <input asp-for="Price" class="form-control" type="number" step="0.01" min="0" />
            <span asp-validation-for="Price" class="field-error"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary">Update Product</button>
            <a asp-action="Index" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }